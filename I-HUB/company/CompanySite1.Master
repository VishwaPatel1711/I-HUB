                                    <span class="no-icon"><asp:Label runat="server" ID="lbl"></asp:Label></span>
                                </a>
                                <div class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                                     <a class="dropdown-item" href="company_profile.aspx">Profile</a>
